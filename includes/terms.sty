% Add a period to the end of an abbreviation unless there's one
% already, then \xspace.
\makeatletter
\DeclareRobustCommand\onedot{\futurelet\@let@token\@onedot}
\def\@onedot{\ifx\@let@token.\else.\null\fi\xspace}

\def\eg{\emph{e.g}\onedot} 
\def\Eg{\emph{E.g}\onedot}
\def\ie{\emph{i.e}\onedot} 
\def\Ie{\emph{I.e}\onedot}
\def\etc{\emph{etc}\onedot} 
\def\etal{\emph{et al}\onedot}
\makeatother

\newcommand{\rsec}[1]{Section~\ref{sec:#1}}
\newcommand{\rssec}[1]{Subsection~\ref{ssec:#1}}
\newcommand{\rtab}[1]{Table~\ref{tab:#1}}
\newcommand{\rfig}[1]{Figure~\ref{fig:#1}}
\newcommand{\rlst}[1]{Listing~\ref{lst:#1}}
\newcommand{\ralg}[1]{Algorithm~\ref{alg:#1}}
\newcommand{\rdef}[1]{Definition~\ref{def:#1}}
\newcommand{\req}[1]{Equation~\ref{eq:#1}}

\DeclarePairedDelimiter{\ceil}{\lceil}{\rceil}
\DeclarePairedDelimiter{\floor}{\lfloor}{\rfloor}

\def\algname{ZConv\xspace}
\def\algfullname{Zero-Copy Convolution\xspace}

\newcommand{\code}[1]{\texttt{#1}}

\newif\iffirst
\newcommand\printfirstu[1]{\code{#1}\firstfalse} % Do not use directly
\newcommand\printu[1]{\iffirst\printfirstu{#1}\else\_\code{#1}\fi} % Do not use directly
\NewDocumentCommand\codeus{>{\SplitList{,}}m}{
    \firsttrue\unskip\mbox{\ProcessList{#1}{\printu}}\xspace
}

\renewcommand{\fbox}[1]{\tikz[baseline=(char.base)]{
            \node[shape=circle,draw,inner sep=1.2pt] (char) {#1};}}